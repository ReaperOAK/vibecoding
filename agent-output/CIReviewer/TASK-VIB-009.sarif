{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "CIReviewer",
          "version": "1.0.0",
          "informationUri": "https://sarifweb.azurewebsites.net/",
          "rules": [
            {
              "id": "CI-CPLX-001",
              "name": "CyclomaticComplexityThreshold",
              "shortDescription": {
                "text": "Cyclomatic complexity exceeds threshold"
              }
            },
            {
              "id": "CI-COGN-001",
              "name": "CognitiveComplexityThreshold",
              "shortDescription": {
                "text": "Cognitive complexity exceeds threshold"
              }
            },
            {
              "id": "CI-PROC-001",
              "name": "MissingSecurityHandoff",
              "shortDescription": {
                "text": "Expected Security stage summary artifact is missing"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "CI-CPLX-001",
          "level": "warning",
          "message": {
            "text": "Function _extract_stage_counts has cyclomatic complexity 11 (threshold 10)."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": ".github/mcp-servers/ticket-server/server.py"
                },
                "region": {
                  "startLine": 221
                }
              }
            }
          ]
        },
        {
          "ruleId": "CI-COGN-001",
          "level": "warning",
          "message": {
            "text": "Function _extract_stage_counts has cognitive complexity 16 (threshold 15)."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": ".github/mcp-servers/ticket-server/server.py"
                },
                "region": {
                  "startLine": 221
                }
              }
            }
          ]
        },
        {
          "ruleId": "CI-PROC-001",
          "level": "warning",
          "message": {
            "text": "Security handoff summary file agent-output/Security/TASK-VIB-009.md not found; proceeding based on ticket stage claim and QA evidence."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "ticket-state/CI/TASK-VIB-009.json"
                },
                "region": {
                  "startLine": 1
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
