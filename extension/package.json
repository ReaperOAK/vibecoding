{
  "name": "vibecoding",
  "displayName": "Vibecoding - Multi-Agent Development System",
  "description": "Ticket-driven AI development with 14 specialized agents",
  "version": "0.1.0",
  "publisher": "vibecoding",
  "license": "MIT",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "vibecoding",
        "fullName": "Vibecoding Ticket Manager",
        "icon": "$(sync-spinning)",
        "isStubbed": false
      }
    ],
    "commands": [
      {
        "command": "vibecoding.scaffold",
        "title": "Vibecoding: Scaffold Agent Infrastructure"
      },
      {
        "command": "vibecoding.refreshAgents",
        "title": "Vibecoding: Refresh Agent Templates"
      },
      {
        "command": "vibecoding.syncTickets",
        "title": "Vibecoding: Sync Tickets"
      },
      {
        "command": "vibecoding.refreshTickets",
        "title": "Vibecoding: Refresh Tickets"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vibecoding-tickets",
          "title": "Vibecoding Tickets",
          "icon": "resources/tickets.svg"
        }
      ]
    },
    "views": {
      "vibecoding-tickets": [
        {
          "id": "vibecoding-tickets-view",
          "name": "Tickets"
        }
      ]
    },
    "configuration": {
      "title": "Vibecoding",
      "properties": {
        "vibecoding.autoScaffold": {
          "type": "boolean",
          "default": true,
          "description": "Auto-scaffold .github/ structure on new workspaces"
        },
        "vibecoding.enableHooks": {
          "type": "boolean",
          "default": false,
          "description": "Enable agent hooks (requires VS Code hooks Preview feature)"
        },
        "vibecoding.ticketSyncOnStart": {
          "type": "boolean",
          "default": true,
          "description": "Auto-sync tickets on session start"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "lint": "eslint src --max-warnings=0",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package --out vibecoding.vsix",
    "test": "jest --config ../jest.config.js",
    "test:coverage": "jest --config ../jest.config.js --coverage",
    "test:legacy": "tsc --strict --module commonjs --target ES2022 --esModuleInterop --skipLibCheck --types node --outDir out src/ticketTreeProvider.ts src/ticketTreeProvider.test.ts && node ./out/ticketTreeProvider.test.js"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/vscode": "^1.100.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^10.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.8.0"
  }
}
