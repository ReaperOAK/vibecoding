// Universal tool set — available to all agents
// Reference with #universal in agent tools array
{
  "name": "universal",
  "description": "Core tools every agent needs for navigation, execution, and state management",
  "tools": [
    "vscode",
    "execute",
    "read",
    "search",
    "web",
    "browser",
    "github/*",
    "io.github.tavily-ai/tavily-mcp/*"
  ]
}
