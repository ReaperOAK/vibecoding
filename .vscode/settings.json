{
  // Hook file locations — tells VS Code where to find agent lifecycle hooks
  "chat.hookFilesLocations": [
    ".github/hooks"
  ],

  // Agent features — enable agent mode capabilities
  "chat.agent.enabled": true,

  // Custom instructions — ensure .github/instructions/ files are loaded
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,

  // Skill files — ensure .github/skills/ SKILL.md files are loaded
  "chat.skillFilesLocations": [
    ".github/skills"
  ],

  // Agent files — ensure .github/agents/ .agent.md files are loaded
  "chat.agentFilesLocations": [
    ".github/agents"
  ],

  // Prompt files — ensure .github/prompts/ .prompt.md files are loaded
  "chat.promptFilesLocations": [
    ".github/prompts"
  ]
}
